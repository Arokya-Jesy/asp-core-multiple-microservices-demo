# JWT Configuration - Environment Variables
# Copy this to .env and fill in your actual values
# In production, set these in your cloud provider's secret management

# Secret key for signing JWT tokens (minimum 32 characters)
JWT_SECRETKEY=YourSuperSecretKeyThatIsAtLeast32CharactersLong123456

# JWT Issuer (typically the auth service name)
JWT_ISSUER=AuthMicroservice

# JWT Audience (comma-separated list of services that can consume the token)
JWT_AUDIENCE=ProductMicroservice

# ASP.NET Core Environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Database connection strings (override defaults if needed)
# CONNECTIONSTRINGS__DEFAULTCONNECTION=Server=localhost;Database=YourDB;...
